# Copy this to .env for local dev.
# In Replit, add these as Secrets (wrench icon → Secrets).
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
# The bot uses SQLite (snag-bot/database/snag.db) — no DATABASE_URL needed.
# If you're running on Replit with a Reserved VM or a persistent filesystem,
# snag.db survives restarts inside the filesystem.  If you switch to Autoscale
# or a fresh-checkout deployment that does NOT persist the working directory,
# migrate to Replit's built-in PostgreSQL integration instead (ask the Agent to
# add one) so data is never wiped on redeploy.
